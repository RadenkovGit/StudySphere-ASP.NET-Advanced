@model ReviewEditInputModel
@{
    ViewData["Title"] = "Edit Review";
}
<h1>Edit Review</h1>
<form method="post" class="card card-body shadow-sm">
    <input asp-for="Id" type="hidden" />
    <div class="mb-3">
        <label asp-for="Rating" class="form-label"></label>
        <input asp-for="Rating" class="form-control" min="1" max="5" />
        <span asp-validation-for="Rating" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Comment" class="form-label"></label>
        <textarea asp-for="Comment" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Comment" class="text-danger"></span>
    </div>
    <button class="btn btn-dark">Update</button>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
