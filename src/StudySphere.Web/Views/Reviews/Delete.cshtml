@{
    ViewData["Title"] = "Delete Review";
}
<h1>Delete Review</h1>
<div class="alert alert-warning">Are you sure you want to delete this review?</div>
<form asp-action="ConfirmDelete" method="post">
    <input type="hidden" name="id" value="@ViewBag.ReviewId" />
    <button class="btn btn-danger">Delete</button>
    <a asp-action="Mine" class="btn btn-outline-secondary">Cancel</a>
</form>
