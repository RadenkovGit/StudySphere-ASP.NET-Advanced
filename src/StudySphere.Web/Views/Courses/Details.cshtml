@model CourseDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}
<div class="row g-4">
    <div class="col-lg-5">
        <img src="@Model.ImageUrl" class="img-fluid rounded shadow-sm" alt="@Model.Title" />
    </div>
    <div class="col-lg-7">
        <span class="badge bg-primary mb-2">@Model.Category</span>
        <h1>@Model.Title</h1>
        <p class="text-muted">Instructor: @Model.InstructorName</p>
        <p>@Model.Description</p>
        <p><strong>Start date:</strong> @Model.StartDate.ToString("dd MMM yyyy")</p>
        <p><strong>Duration:</strong> @Model.DurationWeeks weeks</p>
        <p><strong>Average rating:</strong> @(Model.AverageRating == 0 ? "No reviews yet" : Model.AverageRating.ToString("F1"))</p>
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            @if (!Model.IsEnrolled)
            {
                <form asp-action="Enroll" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button class="btn btn-dark">Enroll now</button>
                </form>
            }
            else
            {
                <span class="badge bg-success">Enrolled</span>
            }
        }
    </div>
</div>

<section class="mt-5">
    <h2>Lessons</h2>
    <div class="list-group">
        @foreach (var lesson in Model.Lessons)
        {
            <a asp-controller="Lessons" asp-action="Details" asp-route-id="@lesson.Id" class="list-group-item list-group-item-action d-flex justify-content-between">
                <span>@lesson.Order. @lesson.Title</span>
                <span>@lesson.EstimatedMinutes min</span>
            </a>
        }
    </div>
</section>

<section class="mt-5">
    <h2>Resources</h2>
    <div class="row">
        @foreach (var resource in Model.Resources)
        {
            <div class="col-md-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5>@resource.Title</h5>
                        <p>@resource.Summary</p>
                        <a href="@resource.Url" target="_blank" rel="noopener noreferrer" class="btn btn-outline-dark btn-sm">Open resource</a>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

<section class="mt-5">
    <h2>Reviews</h2>
    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <form asp-controller="Reviews" asp-action="Create" method="post" class="card card-body mb-4">
            <input type="hidden" name="CourseId" value="@Model.Id" />

            <div class="mb-3">
                <label for="Rating" class="form-label">Rating</label>
                <input id="Rating" name="Rating" type="number" class="form-control" min="1" max="5" />
            </div>

            <div class="mb-3">
                <label for="Comment" class="form-label">Comment</label>
                <textarea id="Comment" name="Comment" class="form-control" rows="3"></textarea>
            </div>

            <button class="btn btn-dark">Add review</button>
        </form>
    }

    @foreach (var review in Model.Reviews)
    {
        <div class="border rounded p-3 mb-3">
            <div class="d-flex justify-content-between">
                <strong>@review.Author</strong>
                <span class="badge bg-secondary">@review.Rating / 5</span>
            </div>
            <p class="mb-1 mt-2">@review.Comment</p>
            <small class="text-muted">@review.CreatedOn.ToString("dd MMM yyyy")</small>
        </div>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
