@model ResourceListItemViewModel
@{
    ViewData["Title"] = Model.Title;
}
<h1>@Model.Title</h1>
<p class="text-muted">@Model.CourseTitle</p>
<div class="card shadow-sm">
    <div class="card-body">
        <p>@Model.Summary</p>
        <a href="@Model.Url" target="_blank" rel="noopener noreferrer" class="btn btn-dark">Open resource</a>
    </div>
</div>
