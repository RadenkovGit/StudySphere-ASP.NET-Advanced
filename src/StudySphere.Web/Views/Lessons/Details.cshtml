@model LessonDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}
<div class="mb-3">
    <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.CourseId" class="btn btn-outline-secondary btn-sm">Back to course</a>
</div>
<h1>@Model.Order. @Model.Title</h1>
<p class="text-muted">@Model.CourseTitle • @Model.EstimatedMinutes min</p>
<div class="card shadow-sm">
    <div class="card-body">
        <p>@Model.Content</p>
    </div>
</div>
