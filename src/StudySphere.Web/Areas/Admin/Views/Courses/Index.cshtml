@model IEnumerable<CourseCardViewModel>
@{
    ViewData["Title"] = "Manage Courses";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Manage Courses</h1>
    <a asp-action="Create" class="btn btn-dark">Create Course</a>
</div>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Category</th>
            <th>Instructor</th>
            <th>Start Date</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var course in Model)
    {
        <tr>
            <td>@course.Title</td>
            <td>@course.Category</td>
            <td>@course.InstructorName</td>
            <td>@course.StartDate.ToString("dd MMM yyyy")</td>
            <td>
                <a asp-action="Edit" asp-route-id="@course.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@course.Id" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
