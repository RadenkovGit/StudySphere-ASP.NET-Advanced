@model IEnumerable<AdminCategoryInputModel>
@{
    ViewData["Title"] = "Manage Categories";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Manage Categories</h1>
    <a asp-action="Create" class="btn btn-dark">Create Category</a>
</div>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var category in Model)
    {
        <tr>
            <td>@category.Name</td>
            <td>@category.Description</td>
            <td>
                <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@category.Id" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
